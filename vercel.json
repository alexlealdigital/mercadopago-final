{
  "version": 2,
  "builds": [
    {
      "src": "api/cobrancas.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "/api/cobrancas.py",
      "methods": ["POST"]
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/cobrancas.py"
    }
  ]
}